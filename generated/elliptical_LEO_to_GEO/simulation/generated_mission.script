BeginMissionSequence;

% ============================================================================
% Phase: phase_001_initial - Initial state
% ============================================================================
Report RF_initial_state TargetSat.UTCGregorian TargetSat.ElapsedSecs TargetSat.EarthMJ2000Eq.X TargetSat.EarthMJ2000Eq.Y TargetSat.EarthMJ2000Eq.Z TargetSat.EarthMJ2000Eq.VX TargetSat.EarthMJ2000Eq.VY TargetSat.EarthMJ2000Eq.VZ TargetSat.Earth.SMA TargetSat.Earth.ECC TargetSat.EarthMJ2000Eq.INC TargetSat.EarthMJ2000Eq.RAAN TargetSat.EarthMJ2000Eq.AOP TargetSat.Earth.TA;

% ============================================================================
% Phase: phase_002_initial_coast - Initial parking-orbit coast
% ============================================================================
% Event: event_initial_coast
% Event-driven initial parking-orbit coast before transfer targeting events.
Propagate EarthProp(TargetSat) { TargetSat.ElapsedSecs = 10800.0 };
Report RF_post_initial_coast_report_post_initial_coast TargetSat.UTCGregorian TargetSat.ElapsedSecs TargetSat.EarthMJ2000Eq.X TargetSat.EarthMJ2000Eq.Y TargetSat.EarthMJ2000Eq.Z TargetSat.EarthMJ2000Eq.VX TargetSat.EarthMJ2000Eq.VY TargetSat.EarthMJ2000Eq.VZ TargetSat.Earth.SMA TargetSat.Earth.ECC TargetSat.EarthMJ2000Eq.INC TargetSat.EarthMJ2000Eq.RAAN TargetSat.EarthMJ2000Eq.AOP TargetSat.Earth.TA;

% ============================================================================
% Phase: phase_003_transfer_injection - Phased departure node maneuver
% ============================================================================
% Event: event_transfer_injection
% Seeded phased departure node for transfer_injection
Propagate EarthProp(TargetSat) { TargetSat.Earth.TA = 150.0 };
Maneuver TransferInjection(TargetSat);
Report RF_post_transfer_injection_report_post_transfer_injection TargetSat.UTCGregorian TargetSat.ElapsedSecs TargetSat.EarthMJ2000Eq.X TargetSat.EarthMJ2000Eq.Y TargetSat.EarthMJ2000Eq.Z TargetSat.EarthMJ2000Eq.VX TargetSat.EarthMJ2000Eq.VY TargetSat.EarthMJ2000Eq.VZ TargetSat.Earth.SMA TargetSat.Earth.ECC TargetSat.EarthMJ2000Eq.INC TargetSat.EarthMJ2000Eq.RAAN TargetSat.EarthMJ2000Eq.AOP TargetSat.Earth.TA;

% ============================================================================
% Phase: phase_004_orbit_insertion - Apoapsis maneuver
% ============================================================================
% Event: event_orbit_insertion
% orbital_event:apoapsis; compiled_as:true_anomaly
Propagate EarthProp(TargetSat) { TargetSat.Earth.TA = 180 };
Maneuver OrbitInsertion(TargetSat);
Report RF_post_orbit_insertion_report_post_orbit_insertion TargetSat.UTCGregorian TargetSat.ElapsedSecs TargetSat.EarthMJ2000Eq.X TargetSat.EarthMJ2000Eq.Y TargetSat.EarthMJ2000Eq.Z TargetSat.EarthMJ2000Eq.VX TargetSat.EarthMJ2000Eq.VY TargetSat.EarthMJ2000Eq.VZ TargetSat.Earth.SMA TargetSat.Earth.ECC TargetSat.EarthMJ2000Eq.INC TargetSat.EarthMJ2000Eq.RAAN TargetSat.EarthMJ2000Eq.AOP TargetSat.Earth.TA;

% ============================================================================
% Phase: phase_005_post_insertion_coast - Post-insertion two-day propagation
% ============================================================================
Propagate EarthProp(TargetSat) { TargetSat.ElapsedSecs = 172800.0 };

% ============================================================================
% Phase: phase_006_final_state - Final state
% ============================================================================
Report RF_final_state_checkpoint TargetSat.UTCGregorian TargetSat.ElapsedSecs TargetSat.EarthMJ2000Eq.X TargetSat.EarthMJ2000Eq.Y TargetSat.EarthMJ2000Eq.Z TargetSat.EarthMJ2000Eq.VX TargetSat.EarthMJ2000Eq.VY TargetSat.EarthMJ2000Eq.VZ TargetSat.Earth.SMA TargetSat.Earth.ECC TargetSat.EarthMJ2000Eq.INC TargetSat.EarthMJ2000Eq.RAAN TargetSat.EarthMJ2000Eq.AOP TargetSat.Earth.TA;
