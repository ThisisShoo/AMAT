%----------------------------------------

Create ForceModel EarthFM;
EarthFM.CentralBody = Earth;
EarthFM.PrimaryBodies = { Earth };
EarthFM.Drag = None;
EarthFM.SRP = Off;
EarthFM.RelativisticCorrection = Off;
EarthFM.ErrorControl = RSSStep;
EarthFM.GravityField.Earth.Degree = 0;
