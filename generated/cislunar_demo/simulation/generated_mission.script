% Sparse checkpoints are produced only at explicit mission_spec.json checkpoint steps.


%----------------------------------------
%---------- SPICE / External Dependencies
%----------------------------------------



%----------------------------------------
%---------- CoordinateSystems
%----------------------------------------

Create CoordinateSystem LunaMJ2000Eq;
GMAT LunaMJ2000Eq.Origin = Luna;
GMAT LunaMJ2000Eq.Axes = MJ2000Eq;
Create CoordinateSystem EarthLunaRotating;
GMAT EarthLunaRotating.Origin = Earth;
GMAT EarthLunaRotating.Axes = ObjectReferenced;
GMAT EarthLunaRotating.Primary = Earth;
GMAT EarthLunaRotating.Secondary = Luna;
GMAT EarthLunaRotating.XAxis = R;
GMAT EarthLunaRotating.ZAxis = N;
Create CoordinateSystem LunaEarthRotating;
GMAT LunaEarthRotating.Origin = Luna;
GMAT LunaEarthRotating.Axes = ObjectReferenced;
GMAT LunaEarthRotating.Primary = Luna;
GMAT LunaEarthRotating.Secondary = Earth;
GMAT LunaEarthRotating.XAxis = R;
GMAT LunaEarthRotating.ZAxis = N;
%----------------------------------------
%---------- Spacecraft
%----------------------------------------

Create Spacecraft CislunarSat;
CislunarSat.DateFormat = UTCGregorian;
CislunarSat.Epoch = '01 Jun 2026 00:00:00.000';
CislunarSat.CoordinateSystem = EarthMJ2000Eq;
CislunarSat.DisplayStateType = Cartesian;
CislunarSat.X = -4947.9535435061525;
CislunarSat.Y = 4053.0644613947075;
CislunarSat.Z = 1920.398043235261;
CislunarSat.VX = -5.1791178775370375;
CislunarSat.VY = -4.963716277224432;
CislunarSat.VZ = -2.868036985421945;
CislunarSat.DryMass = 1000.0;
CislunarSat.Cd = 2.2;
CislunarSat.Cr = 1.8;
CislunarSat.DragArea = 8.0;
CislunarSat.SRPArea = 12.0;

%----------------------------------------
%---------- ForceModels
%----------------------------------------

Create ForceModel EarthLuna8x8;
EarthLuna8x8.CentralBody = Earth;
EarthLuna8x8.PrimaryBodies = { Earth };
EarthLuna8x8.PointMasses = { Sun, Luna };
EarthLuna8x8.Drag = None;
EarthLuna8x8.SRP = Off;
EarthLuna8x8.RelativisticCorrection = Off;
EarthLuna8x8.ErrorControl = RSSStep;
EarthLuna8x8.GravityField.Earth.Degree = 8;
EarthLuna8x8.GravityField.Earth.Order = 8;
EarthLuna8x8.GravityField.Earth.StmLimit = 100;
EarthLuna8x8.GravityField.Earth.PotentialFile = 'JGM2.cof';
EarthLuna8x8.GravityField.Earth.TideModel = 'None';

%----------------------------------------
%---------- Propagators
%----------------------------------------

Create Propagator CislunarProp;
CislunarProp.FM = EarthLuna8x8;
CislunarProp.Type = RungeKutta89;
CislunarProp.InitialStepSize = 60.0;
CislunarProp.Accuracy = 1e-09;
CislunarProp.MinStep = 0.1;
CislunarProp.MaxStep = 1800.0;
CislunarProp.MaxStepAttempts = 50;
CislunarProp.StopIfAccuracyIsViolated = true;

%----------------------------------------
%---------- Burns
%----------------------------------------

Create ImpulsiveBurn LOICircularizeSeed;
LOICircularizeSeed.CoordinateSystem = Local;
LOICircularizeSeed.Origin = Luna;
LOICircularizeSeed.Axes = VNB;
LOICircularizeSeed.Element1 = -0.85;
LOICircularizeSeed.Element2 = 0.0;
LOICircularizeSeed.Element3 = 0.0;
LOICircularizeSeed.DecrementMass = false;
LOICircularizeSeed.Isp = 300;
LOICircularizeSeed.GravitationalAccel = 9.81;

Create ImpulsiveBurn TLISeed;
TLISeed.CoordinateSystem = Local;
TLISeed.Origin = Earth;
TLISeed.Axes = VNB;
TLISeed.Element1 = 3.092757101421149;
TLISeed.Element2 = -7.610334121841048e-16;
TLISeed.Element3 = -0.5976864128033639;
TLISeed.DecrementMass = false;
TLISeed.Isp = 300;
TLISeed.GravitationalAccel = 9.81;

