%----------------------------------------
%---------- Mission Sequence
%----------------------------------------

BeginMissionSequence;

% ============================================================================
% Phase: cislunar_transfer - Impulsive cislunar transfer
% ============================================================================
Maneuver TLISeed(CislunarSat);
Report RF_post_tli CislunarSat.UTCGregorian CislunarSat.ElapsedSecs CislunarSat.EarthMJ2000Eq.X CislunarSat.EarthMJ2000Eq.Y CislunarSat.EarthMJ2000Eq.Z CislunarSat.EarthMJ2000Eq.VX CislunarSat.EarthMJ2000Eq.VY CislunarSat.EarthMJ2000Eq.VZ CislunarSat.Earth.SMA CislunarSat.Earth.ECC CislunarSat.EarthMJ2000Eq.INC CislunarSat.EarthMJ2000Eq.RAAN CislunarSat.EarthMJ2000Eq.AOP CislunarSat.Earth.TA;
% Event: lunar_perilune_capture
% orbital_event:periapsis; compiled_as:true_anomaly
Propagate CislunarProp(CislunarSat) { CislunarSat.Luna.TA = 0 };
Maneuver LOICircularizeSeed(CislunarSat);
Report RF_post_loi_report_post_loi CislunarSat.UTCGregorian CislunarSat.ElapsedSecs CislunarSat.LunaMJ2000Eq.X CislunarSat.LunaMJ2000Eq.Y CislunarSat.LunaMJ2000Eq.Z CislunarSat.LunaMJ2000Eq.VX CislunarSat.LunaMJ2000Eq.VY CislunarSat.LunaMJ2000Eq.VZ CislunarSat.Luna.SMA CislunarSat.Luna.ECC CislunarSat.LunaMJ2000Eq.INC CislunarSat.LunaMJ2000Eq.RAAN CislunarSat.LunaMJ2000Eq.AOP CislunarSat.Luna.TA;
Propagate CislunarProp(CislunarSat) { CislunarSat.ElapsedSecs = 172800.0 };
