{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amat.local/schemas/target_problem.schema.json",
  "title": "AMAT TargetProblem",
  "type": "object",
  "required": ["schema_version", "problem_id", "transfer_strategy", "initial_state", "target"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "problem_id": {"type": "string", "minLength": 1},
    "mission_id": {"type": "string", "minLength": 1},
    "transfer_strategy": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"enum": ["hohmann_transfer", "two_impulse_apsidal_transfer"]},
        "central_body": {"type": "string", "minLength": 1},
        "central_body_radius": {"$ref": "#/$defs/quantity"},
        "central_body_mu": {"$ref": "#/$defs/quantity"},
        "stationary_orbit_radius": {"$ref": "#/$defs/quantity"},
        "phase_policy": {"$ref": "#/$defs/phase_policy"},
        "maneuver_policy": {
          "oneOf": [
            {"enum": ["valid_node_low_speed"]},
            {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {"enum": ["valid_node_low_speed"]},
                "maneuver_model": {"enum": ["impulsive", "finite"]},
                "departure_event": {"$ref": "#/$defs/departure_event"},
                "arrival_event": {"$ref": "#/$defs/arrival_event"},
                "allow_departure_phasing": {"type": "boolean"},
                "prefer_apsis_alignment": {"type": "boolean"},
                "fallback": {"enum": ["split_at_nearest_valid_node"]},
                "merge_maneuver_angle_tolerance_deg": {"type": "number", "minimum": 0}
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "initial_state": {
      "type": "object",
      "required": ["representation"],
      "properties": {
        "representation": {"enum": ["circular_orbit", "keplerian", "cartesian", "cometary"]},
        "central_body": {"type": "string", "minLength": 1},
        "altitude": {"$ref": "#/$defs/quantity"},
        "sma": {"$ref": "#/$defs/quantity"},
        "eccentricity": {"type": "number", "minimum": 0, "exclusiveMaximum": 1},
        "inclination": {"$ref": "#/$defs/quantity"},
        "raan": {"$ref": "#/$defs/quantity"},
        "aop": {"$ref": "#/$defs/quantity"},
        "true_anomaly": {"$ref": "#/$defs/quantity"},
        "periapsis_radius": {"$ref": "#/$defs/quantity"},
        "periapsis_distance": {"$ref": "#/$defs/quantity"},
        "position_km": {"$ref": "#/$defs/vector3"},
        "velocity_km_s": {"$ref": "#/$defs/vector3"},
        "epoch": {"type": "string"},
        "frame": {"type": "string"}
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"enum": ["geostationary_orbit", "circular_orbit", "keplerian_state", "cartesian_state", "cometary_state"]},
        "radius": {"$ref": "#/$defs/quantity"},
        "sma": {"$ref": "#/$defs/quantity"},
        "eccentricity": {"type": "number", "minimum": 0, "exclusiveMaximum": 1},
        "eccentricity_max": {"type": "number", "minimum": 0},
        "inclination": {"$ref": "#/$defs/quantity"},
        "inclination_max": {"$ref": "#/$defs/quantity"},
        "raan": {"$ref": "#/$defs/quantity"},
        "aop": {"$ref": "#/$defs/quantity"},
        "argument_of_latitude": {"$ref": "#/$defs/quantity"},
        "argument_of_latitude_max": {"$ref": "#/$defs/quantity"},
        "angle_tolerance": {"$ref": "#/$defs/quantity"},
        "true_anomaly": {"$ref": "#/$defs/quantity"},
        "periapsis_radius": {"$ref": "#/$defs/quantity"},
        "periapsis_distance": {"$ref": "#/$defs/quantity"},
        "position_km": {"$ref": "#/$defs/vector3"},
        "velocity_km_s": {"$ref": "#/$defs/vector3"}
      },
      "additionalProperties": false
    },
    "limits": {"type": "object"},
    "execution": {"type": "object"},
    "verification": {"type": "object"},
    "metadata": {"type": "object"}
  },
  "$defs": {
    "quantity": {
      "type": "object",
      "required": ["value", "unit"],
      "properties": {
        "value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"type": "number"}
    },
    "departure_event": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "initial_state",
            "true_anomaly",
            "argument_of_latitude",
            "periapsis",
            "apoapsis",
            "ascending_node",
            "descending_node",
            "apsis",
            "node"
          ]
        },
        "value": {"$ref": "#/$defs/quantity"},
        "kind": {
          "enum": [
            "periapsis",
            "apoapsis",
            "ascending",
            "descending",
            "ascending_node",
            "descending_node"
          ]
        }
      },
      "additionalProperties": false
    },
    "arrival_event": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "true_anomaly",
            "argument_of_latitude",
            "periapsis",
            "apoapsis",
            "ascending_node",
            "descending_node",
            "apsis",
            "node"
          ]
        },
        "value": {"$ref": "#/$defs/quantity"},
        "kind": {
          "enum": [
            "periapsis",
            "apoapsis",
            "ascending",
            "descending",
            "ascending_node",
            "descending_node"
          ]
        }
      },
      "additionalProperties": false
    },
    "phase_policy": {
      "type": "object",
      "properties": {
        "mode": {"enum": ["auto", "explicit", "disabled"]},
        "enabled": {"type": "boolean"},
        "allowed_strategies": {
          "type": "array",
          "items": {
            "enum": [
              "coast_to_phase",
              "departure_epoch_shift",
              "transfer_time_adjustment",
              "in_plane_drift",
              "resonant",
              "multi_revolution_transfer",
              "optimized"
            ]
          }
        },
        "objective": {"type": "string"},
        "restore_target_orbit": {"type": "boolean"},
        "max_revolutions": {"type": "integer", "minimum": 1},
        "max_delta_v_km_s": {"type": ["number", "null"], "minimum": 0},
        "target": {"enum": ["argument_of_latitude", "true_anomaly", "mean_anomaly", "longitude", "relative_phase", "time_of_arrival"]},
        "at": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
