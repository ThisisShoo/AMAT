{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CompileResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "backend_id",
    "status",
    "generated_artifacts",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "mission_id": {
      "type": "string"
    },
    "backend_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "partial",
        "failed"
      ]
    },
    "generated_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "type",
          "path",
          "hash"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "backend": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}