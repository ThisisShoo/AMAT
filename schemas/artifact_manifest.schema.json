{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mission_id",
    "bundle_id",
    "created_at",
    "artifacts",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "mission_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "type",
          "path",
          "hash",
          "required_for_replay"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "backend": {
            "type": "string"
          },
          "required_for_replay": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "generated_by",
        "compiler_version"
      ],
      "properties": {
        "generated_by": {
          "type": "string"
        },
        "compiler_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}