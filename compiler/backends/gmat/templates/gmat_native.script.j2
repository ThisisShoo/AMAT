% Generated GMAT script
% MissionSpec: {{ spec.mission_id }}
% This file is deterministic replay output from the MVP compiler.
% Full ephemeris/state history is produced by native GMAT ReportFile subscribers.
% Sparse checkpoints are produced only at explicit mission_spec.json checkpoint steps.


%----------------------------------------
%---------- SPICE / External Dependencies
%----------------------------------------

{% for sk in spice_kernel_sets %}
% SPICE kernel set: {{ sk.id }}{% if sk.description %} - {{ sk.description }}{% endif %}
{% for kernel in sk.kernel_paths %}%   kernel: {{ kernel }}
{% endfor %}
{% if sk.enabled and sk.mode == 'spice_kernel_object' %}
% GMAT SpiceKernel object emission is backend-build-specific and is left as a
% project hook. Keep this declaration as a reproducibility artifact unless your
% GMAT installation's SpiceKernel syntax has been validated.
{% endif %}
{% endfor %}


%----------------------------------------
%---------- CoordinateSystems
%----------------------------------------

{% for cs in coordinate_systems %}
Create CoordinateSystem {{ cs.name }};
GMAT {{ cs.name }}.Origin = {{ cs.origin }};
GMAT {{ cs.name }}.Axes = {{ cs.axes }};
{% if cs.primary is defined and cs.primary %}GMAT {{ cs.name }}.Primary = {{ cs.primary }};
{% endif %}{% if cs.secondary is defined and cs.secondary %}GMAT {{ cs.name }}.Secondary = {{ cs.secondary }};
{% endif %}{% if cs.x_axis is defined and cs.x_axis %}GMAT {{ cs.name }}.XAxis = {{ cs.x_axis }};
{% endif %}{% if cs.y_axis is defined and cs.y_axis %}GMAT {{ cs.name }}.YAxis = {{ cs.y_axis }};
{% endif %}{% if cs.z_axis is defined and cs.z_axis %}GMAT {{ cs.name }}.ZAxis = {{ cs.z_axis }};
{% endif %}{% for field in cs.fields if cs.fields is defined %}GMAT {{ cs.name }}.{{ field.field }} = {{ field.value }};
{% endfor %}
{% endfor %}
%----------------------------------------
%---------- Spacecraft
%----------------------------------------

{% for sc in spec.spacecraft %}
Create Spacecraft {{ sc.name }};
{{ sc.name }}.DateFormat = UTCGregorian;
{{ sc.name }}.Epoch = '{{ gmat_epoch(sc.epoch) }}';
{{ sc.name }}.CoordinateSystem = {{ sc.frame|gmat_frame }};
{% if sc.state_type == "cartesian" %}
{{ sc.name }}.DisplayStateType = Cartesian;
{{ sc.name }}.X = {{ sc.position_km[0] }};
{{ sc.name }}.Y = {{ sc.position_km[1] }};
{{ sc.name }}.Z = {{ sc.position_km[2] }};
{{ sc.name }}.VX = {{ sc.velocity_km_s[0] }};
{{ sc.name }}.VY = {{ sc.velocity_km_s[1] }};
{{ sc.name }}.VZ = {{ sc.velocity_km_s[2] }};
{% elif sc.state_type == "keplerian" %}
{{ sc.name }}.DisplayStateType = Keplerian;
{{ sc.name }}.SMA = {{ sc.sma_km }};
{{ sc.name }}.ECC = {{ sc.ecc }};
{{ sc.name }}.INC = {{ sc.inc_deg }};
{{ sc.name }}.RAAN = {{ sc.raan_deg }};
{{ sc.name }}.AOP = {{ sc.aop_deg }};
{{ sc.name }}.TA = {{ sc.ta_deg }};
{% endif %}
{{ sc.name }}.DryMass = {{ sc.dry_mass_kg }};
{{ sc.name }}.Cd = {{ sc.cd }};
{{ sc.name }}.Cr = {{ sc.cr }};
{{ sc.name }}.DragArea = {{ sc.drag_area_m2 }};
{{ sc.name }}.SRPArea = {{ sc.srp_area_m2 }};
{% if spacecraft_tanks_by_id.get(sc.id) %}
{{ sc.name }}.Tanks = { {{ spacecraft_tanks_by_id[sc.id] | join(', ') }} };
{% endif %}
{% if spacecraft_thrusters_by_id.get(sc.id) %}
{{ sc.name }}.Thrusters = { {{ spacecraft_thrusters_by_id[sc.id] | join(', ') }} };
{% endif %}

{% endfor %}
%----------------------------------------
%---------- ForceModels
%----------------------------------------

{% for fm in spec.force_models %}
Create ForceModel {{ fm.name }};
{{ fm.name }}.CentralBody = {{ fm.central_body }};
{{ fm.name }}.PrimaryBodies = { {{ fm.central_body }} };
{% if fm.point_masses %}
{{ fm.name }}.PointMasses = { {{ fm.point_masses | join(', ') }} };
{% endif %}
{{ fm.name }}.Drag = None;
{{ fm.name }}.SRP = Off;
{{ fm.name }}.RelativisticCorrection = Off;
{{ fm.name }}.ErrorControl = {{ fm.backend_overrides.gmat.error_control }};
{% if fm.gravity.type == "point_mass" %}
{{ fm.name }}.GravityField.{{ fm.central_body }}.Degree = 0;
{{ fm.name }}.GravityField.{{ fm.central_body }}.Order = 0;
{% endif %}
{% if fm.gravity.type == "spherical_harmonic" %}
{{ fm.name }}.GravityField.{{ fm.central_body }}.Degree = {{ fm.gravity.degree }};
{{ fm.name }}.GravityField.{{ fm.central_body }}.Order = {{ fm.gravity.order }};
{{ fm.name }}.GravityField.{{ fm.central_body }}.StmLimit = {{ fm.backend_overrides.gmat.stm_limit }};
{{ fm.name }}.GravityField.{{ fm.central_body }}.PotentialFile = '{{ fm.backend_overrides.gmat.potential_file }}';
{{ fm.name }}.GravityField.{{ fm.central_body }}.TideModel = '{{ fm.backend_overrides.gmat.tide_model }}';
{% endif %}

{% endfor %}
%----------------------------------------
%---------- Propagators
%----------------------------------------

{% for prop in spec.propagators %}
{% set fm = (spec.force_models | selectattr('id', 'equalto', prop.force_model) | list)[0] %}
Create Propagator {{ prop.name }};
{{ prop.name }}.FM = {{ fm.name }};
{{ prop.name }}.Type = {{ prop.integrator }};
{{ prop.name }}.InitialStepSize = {{ prop.initial_step_s }};
{{ prop.name }}.Accuracy = {{ prop.accuracy }};
{{ prop.name }}.MinStep = {{ prop.min_step_s }};
{{ prop.name }}.MaxStep = {{ prop.max_step_s }};
{{ prop.name }}.MaxStepAttempts = 50;
{{ prop.name }}.StopIfAccuracyIsViolated = true;

{% endfor %}
%----------------------------------------
%---------- Burns
%----------------------------------------

{% for burn in burns %}
{% if burn.type == "finite" %}
Create ChemicalTank {{ burn.tank_name }};
{{ burn.tank_name }}.AllowNegativeFuelMass = false;
{{ burn.tank_name }}.FuelMass = {{ burn.fuel_mass_kg }};
{{ burn.tank_name }}.Pressure = 1500;
{{ burn.tank_name }}.Temperature = 20;
{{ burn.tank_name }}.RefTemperature = 20;
{{ burn.tank_name }}.Volume = 1;
{{ burn.tank_name }}.FuelDensity = 1260;
{{ burn.tank_name }}.PressureModel = PressureRegulated;

Create ChemicalThruster {{ burn.thruster_name }};
{% if burn.frame in ["VNB", "LVLH", "MJ2000Eq", "SpacecraftBody"] %}
{{ burn.thruster_name }}.CoordinateSystem = Local;
{{ burn.thruster_name }}.Origin = {{ burn.origin }};
{{ burn.thruster_name }}.Axes = {{ burn.frame }};
{% else %}
{{ burn.thruster_name }}.CoordinateSystem = {{ burn.frame | gmat_frame }};
{% endif %}
{{ burn.thruster_name }}.ThrustDirection1 = {{ burn.direction_unit[0] }};
{{ burn.thruster_name }}.ThrustDirection2 = {{ burn.direction_unit[1] }};
{{ burn.thruster_name }}.ThrustDirection3 = {{ burn.direction_unit[2] }};
{{ burn.thruster_name }}.DutyCycle = {{ burn.duty_cycle }};
{{ burn.thruster_name }}.ThrustScaleFactor = 1;
{{ burn.thruster_name }}.DecrementMass = {{ 'true' if burn.decrement_mass else 'false' }};
{{ burn.thruster_name }}.Tank = { {{ burn.tank_name }} };
{{ burn.thruster_name }}.MixRatio = [1];
{{ burn.thruster_name }}.GravitationalAccel = 9.810000000000001;
{{ burn.thruster_name }}.C1 = {{ burn.thrust_N }};
{% for idx in range(2, 17) %}{{ burn.thruster_name }}.C{{ idx }} = 0;
{% endfor %}{{ burn.thruster_name }}.K1 = {{ burn.isp_s }};
{% for idx in range(2, 17) %}{{ burn.thruster_name }}.K{{ idx }} = 0;
{% endfor %}
Create FiniteBurn {{ burn.name }};
{{ burn.name }}.Thrusters = { {{ burn.thruster_name }} };
{{ burn.name }}.ThrottleLogicAlgorithm = 'MaxNumberOfThrusters';
{% else %}
Create ImpulsiveBurn {{ burn.name }};
{% if burn.frame in ["VNB", "LVLH", "MJ2000Eq", "SpacecraftBody"] %}
{{ burn.name }}.CoordinateSystem = Local;
{{ burn.name }}.Origin = {{ burn.origin }};
{{ burn.name }}.Axes = {{ burn.frame }};
{% else %}
{{ burn.name }}.CoordinateSystem = {{ burn.frame | gmat_frame }};
{% endif %}
{{ burn.name }}.Element1 = {{ burn.delta_v_km_s[0] }};
{{ burn.name }}.Element2 = {{ burn.delta_v_km_s[1] }};
{{ burn.name }}.Element3 = {{ burn.delta_v_km_s[2] }};
{{ burn.name }}.DecrementMass = false;
{{ burn.name }}.Isp = 300;
{{ burn.name }}.GravitationalAccel = 9.81;
{% endif %}

{% endfor %}
%----------------------------------------
%---------- ReportFiles / Outputs
%----------------------------------------

{% for report in reports %}
Create ReportFile {{ report.name }};
GMAT {{ report.name }}.Add = { {{ report.parameters | join(', ') }} };
GMAT {{ report.name }}.SolverIterations = Current;
GMAT {{ report.name }}.Filename = '{{ report.script_path }}';
GMAT {{ report.name }}.Precision = 16;
GMAT {{ report.name }}.WriteHeaders = {{ 'true' if report.include_header else 'false' }};
GMAT {{ report.name }}.LeftJustify = On;
GMAT {{ report.name }}.ZeroFill = Off;
GMAT {{ report.name }}.FixedWidth = true;
GMAT {{ report.name }}.Delimiter = ',';
GMAT {{ report.name }}.ColumnWidth = 23;
GMAT {{ report.name }}.WriteReport = true;

{% endfor %}
{% for report in body_reports %}
Create ReportFile {{ report.name }};
% Viewer body ephemeris fallback. SPICE export will overwrite this file when
% resolved SPICE data is available; otherwise this GMAT-generated body state
% file keeps the visualization layer usable.
GMAT {{ report.name }}.Add = { {{ report.parameters | join(', ') }} };
GMAT {{ report.name }}.SolverIterations = Current;
GMAT {{ report.name }}.Filename = '{{ report.script_path }}';
GMAT {{ report.name }}.Precision = 16;
GMAT {{ report.name }}.WriteHeaders = {{ 'true' if report.include_header else 'false' }};
GMAT {{ report.name }}.LeftJustify = On;
GMAT {{ report.name }}.ZeroFill = Off;
GMAT {{ report.name }}.FixedWidth = true;
GMAT {{ report.name }}.Delimiter = ',';
GMAT {{ report.name }}.ColumnWidth = 23;
GMAT {{ report.name }}.WriteReport = true;

{% endfor %}
{% for report in checkpoints %}
Create ReportFile {{ report.name }};
% Sparse checkpoint snapshot file. This ReportFile is intentionally not an
% active trajectory subscriber; it is written only by explicit Report commands.
GMAT {{ report.name }}.SolverIterations = Current;
GMAT {{ report.name }}.Filename = '{{ report.script_path }}';
GMAT {{ report.name }}.Precision = 16;
GMAT {{ report.name }}.WriteHeaders = false;
GMAT {{ report.name }}.LeftJustify = On;
GMAT {{ report.name }}.ZeroFill = Off;
GMAT {{ report.name }}.FixedWidth = true;
GMAT {{ report.name }}.Delimiter = ',';
GMAT {{ report.name }}.ColumnWidth = 23;
GMAT {{ report.name }}.WriteReport = false;

{% endfor %}
{% for report in stm_outputs %}
% STM artifact request: {{ report.id }}
% AMAT consumes this artifact with targeter.solve_stm_target_state_correction.
% State vector: {{ report.state_vector | join(', ') }}
{% if report.decision_variables %}% Decision variables: {{ report.decision_variables | join(', ') }}
{% endif %}{% if report.has_native_report %}
Create ReportFile {{ report.name }};
GMAT {{ report.name }}.Add = { {{ report.parameters | join(', ') }} };
GMAT {{ report.name }}.SolverIterations = Current;
GMAT {{ report.name }}.Filename = '{{ report.script_path }}';
GMAT {{ report.name }}.Precision = 16;
GMAT {{ report.name }}.WriteHeaders = {{ 'true' if report.include_header else 'false' }};
GMAT {{ report.name }}.LeftJustify = On;
GMAT {{ report.name }}.ZeroFill = Off;
GMAT {{ report.name }}.FixedWidth = true;
GMAT {{ report.name }}.Delimiter = ',';
GMAT {{ report.name }}.ColumnWidth = 23;
GMAT {{ report.name }}.WriteReport = true;
{% else %}
% Native GMAT STM ReportFile is not emitted because targeting.stm.parameters is empty.
% Provide {{ report.path }} from a validated GMAT STM/variational-equation integration before STM correction.
{% endif %}

{% endfor %}
%----------------------------------------
%---------- Mission Sequence
%----------------------------------------

BeginMissionSequence;
{% set ns = namespace(index=0) %}
{% for phase in phases %}

% ============================================================================
% Phase: {{ phase.phase_id }} - {{ phase.name }}
{% if phase.description is defined %}% {{ phase.description }}
{% endif %}% ============================================================================
{% for step in phase.steps %}
{% set ns.index = ns.index + 1 %}
{% if step.type == "propagate" %}
{% set prop = (spec.propagators | selectattr('id', 'equalto', step.propagator) | list)[0] %}
{% set sc = (spec.spacecraft | selectattr('id', 'equalto', step.spacecraft) | list)[0] %}
Propagate {{ prop.name }}({{ sc.name }}) { {{ sc.name }}.ElapsedSecs = {{ step.duration_s }} };
{% elif step.type == "maneuver" %}
{% set burn = burns_by_id[step.burn] %}
{% set sc = (spec.spacecraft | selectattr('id', 'equalto', step.spacecraft) | list)[0] %}
{% if burn.type == "finite" %}
{% set prop = (spec.propagators | selectattr('id', 'equalto', step.propagator) | list)[0] %}
BeginFiniteBurn {{ burn.name }}({{ sc.name }});
Propagate {{ prop.name }}({{ sc.name }}) { {{ sc.name }}.ElapsedSecs = {{ step.duration_s }} };
EndFiniteBurn {{ burn.name }}({{ sc.name }});
{% else %}
Maneuver {{ burn.name }}({{ sc.name }});
{% endif %}
{% elif step.type == "checkpoint" %}
{% for cp in checkpoints if cp.after_step_index == ns.index %}
Report {{ cp.name }} {{ cp.parameters | join(' ') }};
{% endfor %}
{% elif step.type == "event_action" %}
{% set event = events_by_id[step.event_id] %}
{% set prop = (spec.propagators | selectattr('id', 'equalto', event.propagator) | list)[0] %}
{% set sc = (spec.spacecraft | selectattr('id', 'equalto', event.spacecraft) | list)[0] %}
% Event: {{ event.id }}
{% if event.description is defined %}% {{ event.description }}
{% endif %}{% if event.compile_notes is defined %}{% for note in event.compile_notes %}% {{ note }}
{% endfor %}{% endif %}{% if ns.index in zero_distance_event_steps %}% Event stop condition is already satisfied at this step; skipping zero-distance Propagate.
{% else %}Propagate {{ prop.name }}({{ sc.name }}) { {{ event.stop_parameter }} = {{ event.stop_value }} };
{% endif %}
{% for action in event.actions %}
{% if action.type == "maneuver" %}
{% set burn = burns_by_id[action.burn] %}
{% set action_sc = (spec.spacecraft | selectattr('id', 'equalto', action.spacecraft) | list)[0] %}
{% if burn.type == "finite" %}
{% set action_prop_id = action.propagator if action.propagator is defined else event.propagator %}
{% set action_prop = (spec.propagators | selectattr('id', 'equalto', action_prop_id) | list)[0] %}
BeginFiniteBurn {{ burn.name }}({{ action_sc.name }});
Propagate {{ action_prop.name }}({{ action_sc.name }}) { {{ action_sc.name }}.ElapsedSecs = {{ action.duration_s }} };
EndFiniteBurn {{ burn.name }}({{ action_sc.name }});
{% else %}
Maneuver {{ burn.name }}({{ action_sc.name }});
{% endif %}
{% elif action.type in ["checkpoint", "report"] %}
{% for cp in checkpoints if cp.after_step_index == ns.index and cp.event_id == event.id and cp.action_id == action.action_id %}
Report {{ cp.name }} {{ cp.parameters | join(' ') }};
{% endfor %}
{% elif action.type == "custom_gmat" %}
{% for command in action.commands %}
{{ command }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% for cp in checkpoints if cp.after_step_index == ns.index and step.type not in ["checkpoint", "event_action"] %}
Report {{ cp.name }} {{ cp.parameters | join(' ') }};
{% endfor %}
{% endfor %}
{% endfor %}

