"""
Generated Orekit/JPype mission runner.

Source MissionSpec: {{ runtime_spec.mission_id }}
"""

from __future__ import annotations

import argparse
import csv
import json
import math
import os
from datetime import datetime, timezone
from pathlib import Path

try:
    import jpype
    import orekit_jpype as orekit
except Exception as exc:  # pragma: no cover - generated runtime guard
    raise RuntimeError("Orekit runtime requires jpype and orekit_jpype. Install AMAT with the orekit extra and set OREKIT_DATA_PATH.") from exc

MISSION_ID = {{ runtime_spec.mission_id|tojson }}
ROOT = Path(__file__).resolve().parent
OUTPUT_DIR = ROOT / "outputs"
RUNTIME_SPEC = {{ runtime_spec|tojson }}


def _orekit_data_path() -> Path:
    raw = os.environ.get("OREKIT_DATA_PATH")
    if not raw:
        raise EnvironmentError("OREKIT_DATA_PATH is not set. Set it to the orekit-data directory before running this mission.")
    path = Path(raw).expanduser().resolve()
    if not path.is_dir():
        raise NotADirectoryError(f"OREKIT_DATA_PATH is not a directory: {path}")
    if not (path / "UTC-TAI.history").exists() and not (path / "tai-utc.dat").exists():
        raise FileNotFoundError(f"OREKIT_DATA_PATH does not look like an orekit-data directory: {path}")
    return path


def _init_orekit() -> None:
    orekit.initVM()
    from java.io import File
    from org.orekit.data import DataContext, DirectoryCrawler

    manager = DataContext.getDefault().getDataProvidersManager()
    manager.clearProviders()
    manager.addProvider(DirectoryCrawler(File(str(_orekit_data_path()))))


def _date(value: str):
    from org.orekit.time import AbsoluteDate, TimeScalesFactory

    text = value.replace("Z", "+00:00")
    dt = datetime.fromisoformat(text)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    dt = dt.astimezone(timezone.utc)
    utc = TimeScalesFactory.getUTC()
    return AbsoluteDate(dt.year, dt.month, dt.day, dt.hour, dt.minute, dt.second + dt.microsecond / 1_000_000.0, utc)


def _frame(name: str):
    from org.orekit.frames import FramesFactory

    if name not in {"EarthMJ2000Eq", "MJ2000Eq", "EME2000", "LunaMJ2000Eq", "MoonMJ2000Eq"}:
        raise ValueError(f"Orekit backend currently maps only MJ2000Eq/EME2000-like inertial frames; got {name}")
    return FramesFactory.getEME2000()


def _orbit(sc: dict):
    from org.hipparchus.geometry.euclidean.threed import Vector3D
    from org.orekit.orbits import CartesianOrbit, KeplerianOrbit, PositionAngleType
    from org.orekit.utils import PVCoordinates

    mu = float(sc["mu_km3_s2"]) * 1.0e9
    frame = _frame(sc["frame"])
    epoch = _date(sc["epoch"])
    if sc["state_type"] == "cartesian":
        r = [float(v) * 1000.0 for v in sc["position_km"]]
        v = [float(v) * 1000.0 for v in sc["velocity_km_s"]]
        return CartesianOrbit(PVCoordinates(Vector3D(*r), Vector3D(*v)), frame, epoch, mu)
    return KeplerianOrbit(
        float(sc["sma_km"]) * 1000.0,
        float(sc["ecc"]),
        math.radians(float(sc["inc_deg"])),
        math.radians(float(sc["aop_deg"])),
        math.radians(float(sc["raan_deg"])),
        math.radians(float(sc["ta_deg"])),
        PositionAngleType.TRUE,
        frame,
        epoch,
        mu,
    )


def _state_row(sc_name: str, frame_name: str, state, elapsed_s: float) -> dict[str, float | str]:
    pv = state.getPVCoordinates()
    p = pv.getPosition()
    v = pv.getVelocity()
    return {
        f"{sc_name}.ElapsedSecs": float(elapsed_s),
        f"{sc_name}.{frame_name}.X": p.getX() / 1000.0,
        f"{sc_name}.{frame_name}.Y": p.getY() / 1000.0,
        f"{sc_name}.{frame_name}.Z": p.getZ() / 1000.0,
        f"{sc_name}.{frame_name}.VX": v.getX() / 1000.0,
        f"{sc_name}.{frame_name}.VY": v.getY() / 1000.0,
        f"{sc_name}.{frame_name}.VZ": v.getZ() / 1000.0,
    }


def _write_rows(path: Path, rows: list[dict]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    if not rows:
        return
    with path.open("w", newline="", encoding="utf-8") as stream:
        writer = csv.DictWriter(stream, fieldnames=list(rows[0].keys()))
        writer.writeheader()
        writer.writerows(rows)


def run() -> dict:
    from org.orekit.propagation.analytical import KeplerianPropagator

    _init_orekit()
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    spacecraft = {sc["id"]: sc for sc in RUNTIME_SPEC["spacecraft"]}
    propagators = {}
    elapsed = {}
    samples = {}
    states = {}
    for sc_id, sc in spacecraft.items():
        propagators[sc_id] = KeplerianPropagator(_orbit(sc))
        elapsed[sc_id] = 0.0
        states[sc_id] = propagators[sc_id].getInitialState()
        samples[sc_id] = [states[sc_id]]

    checkpoints = {cp["id"]: cp for cp in RUNTIME_SPEC.get("checkpoints", [])}
    checkpoint_rows = []
    for step in RUNTIME_SPEC["sequence"]:
        if step["type"] == "propagate":
            sc_id = step["spacecraft"]
            duration = float(step["duration_s"])
            max_step = max(1.0, float(step.get("max_step_s") or 300.0))
            n = max(1, int(math.ceil(duration / max_step)))
            start = elapsed[sc_id]
            for i in range(1, n + 1):
                t = start + duration * i / n
                target_date = propagators[sc_id].getInitialState().getDate().shiftedBy(t)
                states[sc_id] = propagators[sc_id].propagate(target_date)
                samples[sc_id].append(states[sc_id])
            elapsed[sc_id] = start + duration
        elif step["type"] == "checkpoint":
            cp = checkpoints.get(step.get("checkpoint_id"))
            if cp and cp["spacecraft"] in states:
                sc = spacecraft[cp["spacecraft"]]
                checkpoint_rows.append((cp, _state_row(sc["name"], cp["frame"], states[cp["spacecraft"]], elapsed[cp["spacecraft"]])))

    for output in RUNTIME_SPEC["outputs"]:
        sc = spacecraft[output["spacecraft"]]
        rows = [
            _state_row(sc["name"], output["frame"], state, state.getDate().durationFrom(propagators[output["spacecraft"]].getInitialState().getDate()))
            for state in samples[output["spacecraft"]]
        ]
        _write_rows(ROOT / output["path"], rows)

    for cp, row in checkpoint_rows:
        _write_rows(ROOT / cp["path"], [row])

    report = {
        "mission_id": MISSION_ID,
        "backend_id": "orekit",
        "status": "success",
        "orekit_data_path": str(_orekit_data_path()),
        "jvm_path": jpype.getDefaultJVMPath(),
        "outputs": [item["path"] for item in RUNTIME_SPEC["outputs"]],
        "checkpoints": [item[0]["path"] for item in checkpoint_rows],
    }
    report_path = OUTPUT_DIR / "_OrekitBackendReport.json"
    report_path.write_text(json.dumps(report, indent=2), encoding="utf-8")
    return report


def main() -> int:
    parser = argparse.ArgumentParser(description="Run generated Orekit mission.")
    parser.add_argument("--run", action="store_true", help="Run the generated Orekit propagation.")
    parser.add_argument("--save-script", action="store_true", help="Accepted for compatibility; Orekit backend does not emit a native script.")
    parser.add_argument("--no-save-script", action="store_true", help="Accepted for compatibility with AMAT's generated-script runner.")
    args = parser.parse_args()
    if args.run:
        print(json.dumps(run(), indent=2))
        return 0
    parser.print_help()
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
