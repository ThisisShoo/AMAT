{
  "schema_version": "1.0.0",
  "mission_id": "MEO_demo",
  "mission_name": "Finite-Burn MEO Demonstration",
  "description": "Demonstrative finite-burn raise from a 500 km circular 60 deg LEO to a 2000 km circular target orbit. TWR is 0.05 with constant mass; burn durations are analytic seeds.",
  "conventions": {
    "time_scale": "UTC",
    "distance_unit": "km",
    "velocity_unit": "km/s",
    "angle_unit": "deg",
    "mass_unit": "kg",
    "time_format": "ISO-8601"
  },
  "spacecraft": [
    {
      "id": "meo_demo_sat",
      "name": "MeoDemoSat",
      "epoch": "2026-01-01T00:00:00Z",
      "frame": "EarthMJ2000Eq",
      "state_type": "keplerian",
      "sma_km": 6878.1363,
      "ecc": 0.0,
      "inc_deg": 60.0,
      "raan_deg": 0.0,
      "aop_deg": 0.0,
      "ta_deg": 0.0,
      "dry_mass_kg": 1000.0,
      "drag_area_m2": 8.0,
      "srp_area_m2": 12.0,
      "cd": 2.2,
      "cr": 1.8
    }
  ],
  "force_models": [
    {
      "id": "earth_8x8",
      "name": "Earth8x8",
      "central_body": "Earth",
      "gravity": {
        "type": "spherical_harmonic",
        "degree": 8,
        "order": 8,
        "potential_file": "JGM2.cof"
      },
      "third_body_gravity": {
        "enabled": true,
        "bodies": [
          "Sun",
          "Luna"
        ]
      }
    }
  ],
  "propagators": [
    {
      "id": "earth_prop",
      "name": "EarthProp",
      "force_model": "earth_8x8",
      "integrator": "RungeKutta89",
      "accuracy": 1e-9,
      "initial_step_s": 30.0,
      "min_step_s": 0.1,
      "max_step_s": 300.0
    }
  ],
  "burns": [
    {
      "id": "finite_raise_apogee",
      "name": "FiniteRaiseApogee",
      "type": "finite",
      "frame": "VNB",
      "origin": "Earth",
      "thrust_N": 490.3325,
      "isp_s": 320.0,
      "direction": [
        1.0,
        0.0,
        0.0
      ],
      "decrement_mass": false,
      "duty_cycle": 1.0
    },
    {
      "id": "finite_circularize",
      "name": "FiniteCircularize",
      "type": "finite",
      "frame": "VNB",
      "origin": "Earth",
      "thrust_N": 490.3325,
      "isp_s": 320.0,
      "direction": [
        1.0,
        0.0,
        0.0
      ],
      "decrement_mass": false,
      "duty_cycle": 1.0
    }
  ],
  "events": [
    {
      "id": "meo_apogee_circularize",
      "type": "orbital_event",
      "event": "apoapsis",
      "central_body": "Earth",
      "spacecraft": "meo_demo_sat",
      "propagator": "earth_prop",
      "actions": [
        {
          "action_id": "burn_circularize",
          "type": "maneuver",
          "spacecraft": "meo_demo_sat",
          "burn": "finite_circularize",
          "propagator": "earth_prop",
          "duration_s": 708.0
        }
      ]
    }
  ],
  "mission_sequence": [
    {
      "phase_id": "finite_raise",
      "name": "Finite-burn orbit raise",
      "steps": [
        {
          "step_id": "raise_apogee",
          "type": "maneuver",
          "spacecraft": "meo_demo_sat",
          "burn": "finite_raise_apogee",
          "propagator": "earth_prop",
          "duration_s": 745.0
        },
        {
          "step_id": "circularize_at_apogee",
          "type": "event_action",
          "event_id": "meo_apogee_circularize"
        },
        {
          "step_id": "propagate_12_days",
          "type": "propagate",
          "spacecraft": "meo_demo_sat",
          "propagator": "earth_prop",
          "duration_s": 1036800.0
        }
      ]
    }
  ],
  "outputs": [
    {
      "id": "eci_and_fixed_ephemeris",
      "type": "spacecraft_ephemeris",
      "spacecraft": "meo_demo_sat",
      "frames": [
        "EarthMJ2000Eq",
        "EarthFixed"
      ],
      "state_groups": [
        "elapsed_time",
        "cartesian",
        "keplerian"
      ],
      "path_template": "outputs/_Ephemeris_{spacecraft}_{frame}.csv"
    },
    {
      "id": "earth_ground_track",
      "type": "ground_track",
      "spacecraft": "meo_demo_sat",
      "body": "Earth",
      "path": "outputs/_GroundTrack_{spacecraft}_{body}.csv"
    }
  ],
  "visualization": {
    "enabled": true,
    "auto_export_after_run": true,
    "write_manifest": true,
    "include_spice_body_ephemerides": true
  }
}
